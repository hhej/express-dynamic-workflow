# LLM
GOOGLE_API_KEY=your-gemini-api-key

# Maps
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Search
TAVILY_API_KEY=your-tavily-api-key

# Observability
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# App
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATABASE_PATH=data/express.db
CHECKPOINT_PATH=data/checkpoints.db

# Surcharge Config
BASELINE_DIESEL_PRICE=29.94
SURCHARGE_CAP=0.15
SURCHARGE_FLOOR=-0.05

# Phase 2 additions
GEMINI_MODEL=gemini-2.0-flash
FUEL_FETCH_TIMEOUT=10
ROUTE_CACHE_TTL_SECONDS=900
TRAFFIC_RATIO_BUCKETS=1.1,1.3,1.5,1.8

# Phase 3 additions
FUEL_DATA_TTL_SECONDS=3600
PLANNER_MAX_ITERATIONS=6

# Phase 4 frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Phase 5 additions
HITL_TOTAL_THB_THRESHOLD=500.0
SEARCH_CACHE_TTL_SECONDS=1800

# v1.1 additions — adversarial guardrails (Quick 260509-utd / Phase 10 / Phase 11)
#
# MAX_TOOL_CALLS_PER_TURN: per-turn cap for the tool_call_count reducer.
# guard_input refuses (category='cost_bombing') when a follow-up's count
# reaches this value. Default 6 = 3-5 happy-path tool calls + headroom
# for D-22 retries. Bump to 8 if a legitimate path trips it.
MAX_TOOL_CALLS_PER_TURN=6

# GUARD_INPUT_USE_LLM_FALLBACK: when 'true', guard_input invokes Gemini on
# rules-classifier 'unclear' verdicts as defense-in-depth. Default false
# protects the 15 RPM Gemini budget — the rules pass is the load-bearing
# layer. Flip to true if the adversarial_pack.txt dry-run shows misses.
# Accepts: 1, true, yes, on (case-insensitive).
GUARD_INPUT_USE_LLM_FALLBACK=false

# v1.1 additions — fuel pipeline (Quick 260509-eum / DATA-06)
#
# EXPRESS_SKIP_COLDSTART_REFRESH: when 'true', FastAPI lifespan skips the
# background auto-refresh of data/raw/eppo_diesel_prices.csv on startup.
# Default empty (refresh enabled in production; CSV refreshes if stale per
# the Asia/Bangkok timezone-aware staleness predicate). Tests set this to
# '1' to avoid network attempts during pytest.
EXPRESS_SKIP_COLDSTART_REFRESH=
